FROM dhi.io/python:3-alpine3.23-dev AS builder
WORKDIR /app
COPY src/ src/
RUN python -m py_compile src/speconn/__init__.py && \
    python -m py_compile src/speconn/error.py && \
    python -m py_compile src/speconn/envelope.py && \
    python -m py_compile src/speconn/transport.py && \
    python -m py_compile src/speconn/client.py && \
    python -m py_compile src/speconn/router.py && \
    echo "OK"

FROM scratch
COPY --from=builder /app/src/ /out/
